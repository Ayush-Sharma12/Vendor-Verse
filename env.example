# =============================================================================
# VENDORVERSE - ENVIRONMENT VARIABLES FOR VERCEL DEPLOYMENT
# =============================================================================

# APPLICATION CONFIGURATION
# =============================================================================
VITE_APP_NAME=VendorVerse
VITE_PUBLIC_URL=https://your-domain.vercel.app
VITE_API_URL=https://your-domain.vercel.app/api

# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=production
PORT=3000

# DEVELOPMENT/FEATURE FLAGS
# =============================================================================
VITE_ENABLE_SOURCE_MAPPING=false
VITE_SHOW_DEV_TOOLS=false

# ANALYTICS (Optional)
# =============================================================================
# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=
# Fullstory Integration
VITE_FULLSTORY_ORG_ID=

# VENDOR MANAGEMENT
# =============================================================================
# Vendor API settings
VENDOR_API_TIMEOUT=30000
VENDOR_MAX_LISTINGS=1000

# AUTHENTICATION & SECURITY (Optional for future features)
# =============================================================================
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
SESSION_SECRET=your-session-secret-here-min-32-chars
COOKIE_DOMAIN=.your-domain.vercel.app
COOKIE_SECURE=true
COOKIE_SAME_SITE=Strict

# DATABASE (If using database for vendor storage)
# =============================================================================
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/vendorverse

# MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=vendorverse_user
# DB_PASS=your-secure-password
# DB_NAME=vendorverse

# MongoDB (Alternative)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vendorverse

# STORAGE & CDN (Optional)
# =============================================================================
# AWS S3 for vendor images/documents
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=vendorverse-uploads

# Cloudinary for image optimization
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# PAYMENT PROCESSING (If adding vendor subscription)
# =============================================================================
# Stripe
# STRIPE_PUBLIC_KEY=pk_live_your-key
# STRIPE_SECRET_KEY=sk_live_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-key

# Razorpay (India-based payments)
# RAZORPAY_KEY_ID=your-key-id
# RAZORPAY_KEY_SECRET=your-key-secret

# EMAIL & NOTIFICATIONS
# =============================================================================
# SendGrid for emails
# SENDGRID_API_KEY=your-sendgrid-key
# SENDGRID_FROM_EMAIL=noreply@vendorverse.com

# SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@vendorverse.com

# SMS notifications
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# EXTERNAL APIs (Optional for enhanced features)
# =============================================================================
# Google Maps API for location services
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# OpenAI for AI features
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4

# Weather API for vendor availability context
# OPENWEATHER_API_KEY=your-openweather-key

# LOGGING & MONITORING
# =============================================================================
# Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# Datadog for monitoring
# DATADOG_API_KEY=your-datadog-key
# DATADOG_SITE=datadoghq.com

# LogRocket for session replay and analytics
# LOGROCKET_APP_ID=your-logrocket-id

# SOCIAL MEDIA & INTEGRATIONS
# =============================================================================
# Google OAuth
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# GitHub OAuth (for developer login)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Facebook for login/sharing
# FACEBOOK_APP_ID=your-app-id
# FACEBOOK_APP_SECRET=your-app-secret

# RATE LIMITING & SECURITY
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=https://your-domain.vercel.app

# CACHE CONFIGURATION
# =============================================================================
CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379

# VENDOR-SPECIFIC SETTINGS
# =============================================================================
VENDOR_VERIFICATION_REQUIRED=true
VENDOR_AUTO_APPROVAL=false
VENDOR_IMAGE_MAX_SIZE_MB=5
VENDOR_DESCRIPTION_MAX_CHARS=1000

# FEATURE TOGGLES
# =============================================================================
ENABLE_VENDOR_REGISTRATION=true
ENABLE_VENDOR_VERIFICATION=true
ENABLE_ANTI_FRAUD_DETECTION=true
ENABLE_BUSINESS_HOURS_CHECK=true
ENABLE_VENDOR_ANALYTICS=true
ENABLE_USER_REVIEWS=false
ENABLE_VENDOR_MESSAGING=false

# BUILD & DEPLOYMENT OPTIMIZATION
# =============================================================================
VITE_BUILD_SOURCEMAP=false
VITE_BUILD_MINIFY=true
